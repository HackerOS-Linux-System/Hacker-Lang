! bit.hk — plik konfiguracyjny projektu Hacker Lang
! Format: .hk (HackerOS Configuration Format)
! Brak cudzysłowów w wartościach, komentarze przez !

[project]
-> name    => MojProjekt
-> version => 1.0.0
-> author  => HackerOS Team
-> entry   => source-code/main.hl
-> type    => hl

[dependencies]
-> tui
-> regex
-> json-parser

[build]
-> target  => hl
-> output  => dist/mojprojekt
-> debug   => false
